&lt;&#x2F;span&gt;&lt;span&gt;                {
&lt;&#x2F;span&gt;&lt;span&gt;                    &lt;&#x2F;span&gt;&lt;span style=&quot;color:#b48ead;&quot;&gt;return&lt;&#x2F;span&gt;&lt;span&gt; CustomizedUVs[TextureCoordinateIndex].&lt;&#x2F;span&gt;&lt;span style=&quot;color:#bf616a;&quot;&gt;CompileWithDefault&lt;&#x2F;span&gt;&lt;span&gt;(Compiler, Property);
